# Laravel Backend (.env)

APP_NAME=Kanban
APP_ENV=local
APP_KEY=CHANGE_ME
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/abs/path/to/your/database.sqlite

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Sanctum (local auth, keep secret out of commits)
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

# Frontend origin for CORS / Sanctum
FRONTEND_URL=http://localhost:5173

# Mail / broadcast placeholders (not used in this repo)
MAIL_MAILER=log
BROADCAST_DRIVER=log
